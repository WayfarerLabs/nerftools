{
  // Personal rulesync target configuration (gitignored).
  // Copy this to rulesync.local.jsonc and adjust targets to your AI tool(s).
  //
  // The shared rulesync.jsonc already includes claudecode and copilot — those
  // are the "standard" outputs that get committed. You usually do not need to
  // repeat them here; add only your own personal targets instead.
  // Their generated paths are .gitignored so you won't accidentally commit
  // them.
  //
  // Full target list: npx rulesync generate --help
  "targets": ["cursor"]
}
