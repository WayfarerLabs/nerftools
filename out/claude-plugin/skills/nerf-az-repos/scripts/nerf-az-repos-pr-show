#!/usr/bin/env bash
# nerf-az-repos-pr-show -- Show full details for a pull request as JSON.
# Generated from az-repos manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-repos-pr-show [--project|-p <project>] <pr_id>

Options:
  --project, -p <project>
      Azure DevOps project name or ID (auto-detected from the git remote if omitted)

Arguments:
  <pr_id> (required)
      Pull request ID (numeric)
      Must match: ^[0-9]+$

Maps to: az repos pr show --id <pr_id> <project> --output json

Show full details for a pull request as JSON.
EOF
  exit 1
}

PROJECT=""
_PROJECT_SET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project|-p) if [[ -n "${_PROJECT_SET}" ]]; then echo "error: --project can only be specified once" >&2; exit 1; fi; PROJECT="$2"; _PROJECT_SET=true; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

PR_ID="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-repos-pr-show: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -n "${PR_ID}" ]] && [[ "${PR_ID}" == -* ]]; then
  echo "error: nerf-az-repos-pr-show: <pr_id> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${PR_ID}" ]]; then
  echo "error: nerf-az-repos-pr-show: missing required argument <pr_id>" >&2
  echo "  hint: provide a value for <pr_id>" >&2
  usage
fi

_NERF_PATTERN='^[0-9]+$'
if [[ -n "${PR_ID}" ]] && ! [[ "${PR_ID}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-az-repos-pr-show: argument <pr_id> does not match required pattern" >&2
  echo "  value:   \"${PR_ID}\"" >&2
  echo "  pattern: ^[0-9]+$" >&2
  echo "  hint: value must match ^[0-9]+$" >&2
  exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az repos pr show --id "${PR_ID}" ${PROJECT:+"--project"} ${PROJECT:+"$PROJECT"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az repos pr show --id "${PR_ID}" ${PROJECT:+"--project"} ${PROJECT:+"$PROJECT"} --output json
