#!/usr/bin/env bash
# nerf-az-repos-pr-vote -- Cast or reset a review vote on a pull request. The signed-in identity must be a reviewer (or able to add itself) on the PR. Use "reset" to clear an existing vote.
# Generated from az-repos manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=remote

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-repos-pr-vote [--project|-p <project>] <pr_id> <vote>

Options:
  --project, -p <project>
      Azure DevOps project name or ID (auto-detected from the git remote if omitted)

Arguments:
  <pr_id> (required)
      Pull request ID (numeric)
      Must match: ^[0-9]+$
  <vote> (required)
      Vote to cast
      Allowed values: approve, approve-with-suggestions, reject, reset, wait-for-author

Maps to: az repos pr set-vote --id <pr_id> --vote <vote> <project> --output json

Cast or reset a review vote on a pull request. The signed-in identity must be a reviewer (or able to add itself) on the PR. Use "reset" to clear an existing vote.
EOF
  exit 1
}

PROJECT=""
_PROJECT_SET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project|-p) if [[ -n "${_PROJECT_SET}" ]]; then echo "error: --project can only be specified once" >&2; exit 1; fi; PROJECT="$2"; _PROJECT_SET=true; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

_PR_ID_SET=""
if [[ $# -gt 0 ]]; then
  PR_ID="$1"
  _PR_ID_SET=true
  shift
else
  PR_ID=""
fi
_VOTE_SET=""
if [[ $# -gt 0 ]]; then
  VOTE="$1"
  _VOTE_SET=true
  shift
else
  VOTE=""
fi
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-repos-pr-vote: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -n "${_PR_ID_SET}" ]] && [[ "${PR_ID}" == -* ]]; then
  echo "error: nerf-az-repos-pr-vote: <pr_id> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${PR_ID}" ]]; then
  echo "error: nerf-az-repos-pr-vote: missing required argument <pr_id>" >&2
  echo "  hint: provide a value for <pr_id>" >&2
  usage
fi

_NERF_PATTERN='^[0-9]+$'
if [[ -n "${_PR_ID_SET}" ]] && ! [[ "${PR_ID}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-az-repos-pr-vote: argument <pr_id> does not match required pattern" >&2
  echo "  value:   \"${PR_ID}\"" >&2
  echo "  pattern: ^[0-9]+$" >&2
  echo "  hint: value must match ^[0-9]+$" >&2
  exit 1
fi

if [[ -n "${_VOTE_SET}" ]] && [[ "${VOTE}" == -* ]]; then
  echo "error: nerf-az-repos-pr-vote: <vote> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${VOTE}" ]]; then
  echo "error: nerf-az-repos-pr-vote: missing required argument <vote>" >&2
  echo "  hint: provide a value for <vote>" >&2
  usage
fi

if [[ -n "${_VOTE_SET}" ]] && [[ "${VOTE}" != "approve" && "${VOTE}" != "approve-with-suggestions" && "${VOTE}" != "reject" && "${VOTE}" != "reset" && "${VOTE}" != "wait-for-author" ]]; then
  echo "error: nerf-az-repos-pr-vote: argument <vote> is not an allowed value" >&2
  echo "  value:   \"${VOTE}\"" >&2
  echo "  allowed: approve, approve-with-suggestions, reject, reset, wait-for-author" >&2
  echo "  hint: use one of the allowed values" >&2
  exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az repos pr set-vote --id "${PR_ID}" --vote "${VOTE}" ${PROJECT:+"--project"} ${PROJECT:+"$PROJECT"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az repos pr set-vote --id "${PR_ID}" --vote "${VOTE}" ${PROJECT:+"--project"} ${PROJECT:+"$PROJECT"} --output json
