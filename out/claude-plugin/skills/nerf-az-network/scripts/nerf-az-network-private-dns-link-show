#!/usr/bin/env bash
# nerf-az-network-private-dns-link-show -- Show details for a single virtual network link on a private DNS zone.
# Generated from az-network manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-network-private-dns-link-show --resource-group|-g <resource_group> --zone-name <zone_name> [--subscription <subscription>] <name>

Options:
  --resource-group, -g <resource_group> (required)
      Resource group containing the zone
  --zone-name <zone_name> (required)
      Private DNS zone name
  --subscription <subscription>
      Subscription name or ID (defaults to active)

Arguments:
  <name> (required)
      Link name

Maps to: az network private-dns link vnet show --resource-group <resource_group> --zone-name <zone_name> --name <name> <subscription> --output json

Show details for a single virtual network link on a private DNS zone.
EOF
  exit 1
}

RESOURCE_GROUP=""
_RESOURCE_GROUP_SET=""
ZONE_NAME=""
_ZONE_NAME_SET=""
SUBSCRIPTION=""
_SUBSCRIPTION_SET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --resource-group|-g) if [[ -n "${_RESOURCE_GROUP_SET}" ]]; then echo "error: --resource-group can only be specified once" >&2; exit 1; fi; RESOURCE_GROUP="$2"; _RESOURCE_GROUP_SET=true; shift 2 ;;
    --zone-name) if [[ -n "${_ZONE_NAME_SET}" ]]; then echo "error: --zone-name can only be specified once" >&2; exit 1; fi; ZONE_NAME="$2"; _ZONE_NAME_SET=true; shift 2 ;;
    --subscription) if [[ -n "${_SUBSCRIPTION_SET}" ]]; then echo "error: --subscription can only be specified once" >&2; exit 1; fi; SUBSCRIPTION="$2"; _SUBSCRIPTION_SET=true; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

NAME="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-network-private-dns-link-show: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -z "${RESOURCE_GROUP}" ]]; then
  echo "error: nerf-az-network-private-dns-link-show: missing required option --resource-group" >&2
  echo "  hint: provide --resource-group <value>" >&2
  usage
fi

if [[ -z "${ZONE_NAME}" ]]; then
  echo "error: nerf-az-network-private-dns-link-show: missing required option --zone-name" >&2
  echo "  hint: provide --zone-name <value>" >&2
  usage
fi

if [[ -n "${NAME}" ]] && [[ "${NAME}" == -* ]]; then
  echo "error: nerf-az-network-private-dns-link-show: <name> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${NAME}" ]]; then
  echo "error: nerf-az-network-private-dns-link-show: missing required argument <name>" >&2
  echo "  hint: provide a value for <name>" >&2
  usage
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az network private-dns link vnet show --resource-group "${RESOURCE_GROUP}" --zone-name "${ZONE_NAME}" --name "${NAME}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az network private-dns link vnet show --resource-group "${RESOURCE_GROUP}" --zone-name "${ZONE_NAME}" --name "${NAME}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json
