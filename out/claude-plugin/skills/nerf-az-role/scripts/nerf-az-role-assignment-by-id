#!/usr/bin/env bash
# nerf-az-role-assignment-by-id -- Fetch role assignments by full ID. Wraps "az role assignment list --ids" (the Azure CLI does not have a "show" subcommand for role assignments), so the result is always a JSON array -- typically with one element when the ID exists, empty when it does not.
# Generated from az-role manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-role-assignment-by-id [--subscription <subscription>] <assignment_id>

Options:
  --subscription <subscription>
      Subscription name or ID (defaults to active)

Arguments:
  <assignment_id> (required)
      Full role assignment resource ID

Maps to: az role assignment list --ids <assignment_id> <subscription> --output json

Fetch role assignments by full ID. Wraps "az role assignment list --ids" (the Azure CLI does not have a "show" subcommand for role assignments), so the result is always a JSON array -- typically with one element when the ID exists, empty when it does not.
EOF
  exit 1
}

SUBSCRIPTION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --subscription) if [[ -n "${SUBSCRIPTION}" ]]; then echo "error: --subscription can only be specified once" >&2; exit 1; fi; SUBSCRIPTION="$2"; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

ASSIGNMENT_ID="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-role-assignment-by-id: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -n "${ASSIGNMENT_ID}" ]] && [[ "${ASSIGNMENT_ID}" == -* ]]; then
  echo "error: nerf-az-role-assignment-by-id: <assignment_id> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${ASSIGNMENT_ID}" ]]; then
  echo "error: nerf-az-role-assignment-by-id: missing required argument <assignment_id>" >&2
  echo "  hint: provide a value for <assignment_id>" >&2
  usage
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az role assignment list --ids "${ASSIGNMENT_ID}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az role assignment list --ids "${ASSIGNMENT_ID}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json
