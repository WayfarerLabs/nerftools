#!/usr/bin/env bash
# nerf-kubectl-top-nodes -- Show CPU and memory usage of nodes.
# Generated from kubectl manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "error: nerf-kubectl-top-nodes requires bash 4+. Found bash ${BASH_VERSION:-unknown}" >&2
  echo "  hint: on macOS, install a newer bash via 'brew install bash'" >&2
  exit 1
fi

set -euo pipefail

NERFTOOLS_BRAND="nerf"

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-kubectl-top-nodes [--selector|-l <selector>]

Options:
  --selector, -l <selector>
      Label selector

Maps to: kubectl top nodes <selector>

Show CPU and memory usage of nodes.
EOF
  exit 1
}

SELECTOR=""
_SELECTOR_SET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --selector|-l) if [[ -n "${_SELECTOR_SET}" ]]; then echo "error: --selector can only be specified once" >&2; exit 1; fi; SELECTOR="$2"; _SELECTOR_SET=true; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) echo "error: unknown argument: $1" >&2; usage ;;
  esac
done

for _bin in kubectl; do
  if ! command -v "$_bin" >/dev/null 2>&1; then
    echo "error: nerf-kubectl-top-nodes: required command '$_bin' is not installed or not on PATH" >&2
    exit 127
  fi
done

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(kubectl top nodes ${_SELECTOR_SET:+"--selector"} ${_SELECTOR_SET:+"$SELECTOR"})
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec kubectl top nodes ${_SELECTOR_SET:+"--selector"} ${_SELECTOR_SET:+"$SELECTOR"}
