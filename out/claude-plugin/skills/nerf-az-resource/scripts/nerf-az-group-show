#!/usr/bin/env bash
# nerf-az-group-show -- Show details for a single resource group.
# Generated from az-resource manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-group-show [--subscription <subscription>] <name>

Options:
  --subscription <subscription>
      Subscription name or ID (defaults to active)

Arguments:
  <name> (required)
      Resource group name

Maps to: az group show --name <name> <subscription> --output json

Show details for a single resource group.
EOF
  exit 1
}

SUBSCRIPTION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --subscription) if [[ -n "${SUBSCRIPTION}" ]]; then echo "error: --subscription can only be specified once" >&2; exit 1; fi; SUBSCRIPTION="$2"; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

NAME="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-group-show: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -n "${NAME}" ]] && [[ "${NAME}" == -* ]]; then
  echo "error: nerf-az-group-show: <name> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${NAME}" ]]; then
  echo "error: nerf-az-group-show: missing required argument <name>" >&2
  echo "  hint: provide a value for <name>" >&2
  usage
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az group show --name "${NAME}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az group show --name "${NAME}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json
