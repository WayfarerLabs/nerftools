#!/usr/bin/env bash
# nerf-az-keyvault-network-rule-list -- List explicit network rules on a Key Vault.
# Generated from az-keyvault manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-keyvault-network-rule-list [--resource-group|-g <resource_group>] [--subscription <subscription>] <vault_name>

Options:
  --resource-group, -g <resource_group>
      Resource group containing the vault (optional)
  --subscription <subscription>
      Subscription name or ID (defaults to active)

Arguments:
  <vault_name> (required)
      Key Vault name

Maps to: az keyvault network-rule list --name <vault_name> <resource_group> <subscription> --output json

List explicit network rules on a Key Vault.
EOF
  exit 1
}

RESOURCE_GROUP=""
_RESOURCE_GROUP_SET=""
SUBSCRIPTION=""
_SUBSCRIPTION_SET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --resource-group|-g) if [[ -n "${_RESOURCE_GROUP_SET}" ]]; then echo "error: --resource-group can only be specified once" >&2; exit 1; fi; RESOURCE_GROUP="$2"; _RESOURCE_GROUP_SET=true; shift 2 ;;
    --subscription) if [[ -n "${_SUBSCRIPTION_SET}" ]]; then echo "error: --subscription can only be specified once" >&2; exit 1; fi; SUBSCRIPTION="$2"; _SUBSCRIPTION_SET=true; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

VAULT_NAME="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-keyvault-network-rule-list: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -n "${VAULT_NAME}" ]] && [[ "${VAULT_NAME}" == -* ]]; then
  echo "error: nerf-az-keyvault-network-rule-list: <vault_name> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${VAULT_NAME}" ]]; then
  echo "error: nerf-az-keyvault-network-rule-list: missing required argument <vault_name>" >&2
  echo "  hint: provide a value for <vault_name>" >&2
  usage
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az keyvault network-rule list --name "${VAULT_NAME}" ${RESOURCE_GROUP:+"--resource-group"} ${RESOURCE_GROUP:+"$RESOURCE_GROUP"} ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az keyvault network-rule list --name "${VAULT_NAME}" ${RESOURCE_GROUP:+"--resource-group"} ${RESOURCE_GROUP:+"$RESOURCE_GROUP"} ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json
