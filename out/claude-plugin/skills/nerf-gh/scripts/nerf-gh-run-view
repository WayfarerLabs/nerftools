#!/usr/bin/env bash
# nerf-gh-run-view -- View details of a workflow run
# Generated from gh manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-gh-run-view <run_id>

Arguments:
  <run_id> (required)
      Workflow run ID
      Must match: ^[0-9]+$

Maps to: gh run view <run_id>

View details of a workflow run.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

RUN_ID="${1:-}"
shift 2>/dev/null || true

if [[ -n "${RUN_ID}" ]] && [[ "${RUN_ID}" == -* ]]; then
  echo "error: nerf-gh-run-view: <run_id> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${RUN_ID}" ]]; then
  echo "error: nerf-gh-run-view: missing required argument <run_id>" >&2
  echo "  hint: provide a value for <run_id>" >&2
  usage
fi

_NERF_PATTERN='^[0-9]+$'
if [[ -n "${RUN_ID}" ]] && ! [[ "${RUN_ID}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-gh-run-view: argument <run_id> does not match required pattern" >&2
  echo "  value:   \"${RUN_ID}\"" >&2
  echo "  pattern: ^[0-9]+$" >&2
  echo "  hint: value must match ^[0-9]+$" >&2
  exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  echo "dry-run: gh run view "${RUN_ID}""
  exit 0
fi

exec gh run view "${RUN_ID}"
