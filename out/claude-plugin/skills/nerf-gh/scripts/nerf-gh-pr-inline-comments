#!/usr/bin/env bash
# nerf-gh-pr-inline-comments -- List ALL inline review comments on a pull request, across all reviews. Each comment is tied to a specific line of code. Use gh-pr-review-comments instead when you have a specific review ID and only want that review's comments. Returns the raw GitHub API response; pipe through jq to project the fields you want.
# Generated from gh manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-gh-pr-inline-comments <pr>

Arguments:
  <pr> (required)
      PR number
      Must match: ^[0-9]+$

Maps to: gh api --paginate --slurp repos/{owner}/{repo}/pulls/<pr>/comments

List ALL inline review comments on a pull request, across all reviews. Each comment is tied to a specific line of code. Use gh-pr-review-comments instead when you have a specific review ID and only want that review's comments. Returns the raw GitHub API response; pipe through jq to project the fields you want.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

PR="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-gh-pr-inline-comments: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -n "${PR}" ]] && [[ "${PR}" == -* ]]; then
  echo "error: nerf-gh-pr-inline-comments: <pr> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${PR}" ]]; then
  echo "error: nerf-gh-pr-inline-comments: missing required argument <pr>" >&2
  echo "  hint: provide a value for <pr>" >&2
  usage
fi

_NERF_PATTERN='^[0-9]+$'
if [[ -n "${PR}" ]] && ! [[ "${PR}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-gh-pr-inline-comments: argument <pr> does not match required pattern" >&2
  echo "  value:   \"${PR}\"" >&2
  echo "  pattern: ^[0-9]+$" >&2
  echo "  hint: value must match ^[0-9]+$" >&2
  exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(gh api --paginate --slurp "repos/{owner}/{repo}/pulls/${PR}/comments")
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec gh api --paginate --slurp "repos/{owner}/{repo}/pulls/${PR}/comments"
