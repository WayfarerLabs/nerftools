#!/usr/bin/env bash
# nerf-gh-pr-review-comments -- List inline review comments on a pull request as JSON. These are comments attached to specific lines of code (e.g. from code review).
# Generated from gh manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-gh-pr-review-comments <pr>

Arguments:
  <pr> (required)
      PR number
      Must match: ^[0-9]+$

Maps to: gh api repos/{owner}/{repo}/pulls/<pr>/comments

List inline review comments on a pull request as JSON. These are comments attached to specific lines of code (e.g. from code review)..
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

PR="${1:-}"
shift 2>/dev/null || true

if [[ -n "${PR}" ]] && [[ "${PR}" == -* ]]; then
  echo "error: nerf-gh-pr-review-comments: <pr> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${PR}" ]]; then
  echo "error: nerf-gh-pr-review-comments: missing required argument <pr>" >&2
  echo "  hint: provide a value for <pr>" >&2
  usage
fi

_NERF_PATTERN='^[0-9]+$'
if [[ -n "${PR}" ]] && ! [[ "${PR}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-gh-pr-review-comments: argument <pr> does not match required pattern" >&2
  echo "  value:   \"${PR}\"" >&2
  echo "  pattern: ^[0-9]+$" >&2
  echo "  hint: value must match ^[0-9]+$" >&2
  exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  echo "dry-run: gh api "repos/{owner}/{repo}/pulls/${PR}/comments""
  exit 0
fi

exec gh api "repos/{owner}/{repo}/pulls/${PR}/comments"
