#!/usr/bin/env bash
# nerf-print-range -- Print a line range from a file or stdin. <start> and <end> are 1-indexed inclusive line numbers; both are required. With no <file>, reads from stdin (so this works at the end of a pipeline). For workspace-scoped reads, use print-range-cwd instead. For "lines matching X" rather than a line range, use grep.
# Generated from stdutils manifest. Do not edit directly.
# nerf:threat:read=machine
# nerf:threat:write=none

if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "error: nerf-print-range requires bash 4+. Found bash ${BASH_VERSION:-unknown}" >&2
  echo "  hint: on macOS, install a newer bash via 'brew install bash'" >&2
  exit 1
fi

set -euo pipefail

NERFTOOLS_BRAND="nerf"

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-print-range <start> <end> [<file>]

Arguments:
  <start> (required)
      First line number (1-indexed, inclusive)
      Must match: ^[1-9][0-9]*$
  <end> (required)
      Last line number (1-indexed, inclusive)
      Must match: ^[1-9][0-9]*$
  <file>
      File to read (omit to read from stdin)

Maps to: sed -n <start>,<end>p; <end>q <file>

Print a line range from a file or stdin. <start> and <end> are 1-indexed inclusive line numbers; both are required. With no <file>, reads from stdin (so this works at the end of a pipeline). For workspace-scoped reads, use print-range-cwd instead. For "lines matching X" rather than a line range, use grep.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

_START_SET=""
if [[ $# -gt 0 ]]; then
  START="$1"
  _START_SET=true
  shift
else
  START=""
fi
_END_SET=""
if [[ $# -gt 0 ]]; then
  END="$1"
  _END_SET=true
  shift
else
  END=""
fi
_FILE_SET=""
if [[ $# -gt 0 ]]; then
  FILE="$1"
  _FILE_SET=true
  shift
else
  FILE=""
fi
if [[ $# -gt 0 ]]; then
  echo "error: nerf-print-range: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

for _bin in sed; do
  if ! command -v -- "$_bin" >/dev/null 2>&1; then
    echo "error: nerf-print-range: required command '$_bin' is not installed or not on PATH" >&2
    exit 127
  fi
done

if [[ -n "${_START_SET}" ]] && [[ "${START}" == -* ]]; then
  echo "error: nerf-print-range: <start> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${START}" ]]; then
  echo "error: nerf-print-range: missing required argument <start>" >&2
  echo "  hint: provide a value for <start>" >&2
  usage
fi

_NERF_PATTERN='^[1-9][0-9]*$'
if [[ -n "${_START_SET}" ]] && ! [[ "${START}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-print-range: argument <start> does not match required pattern" >&2
  echo "  value:   \"${START}\"" >&2
  echo "  pattern: ^[1-9][0-9]*$" >&2
  echo "  hint: value must match ^[1-9][0-9]*$" >&2
  exit 1
fi

if [[ -n "${_END_SET}" ]] && [[ "${END}" == -* ]]; then
  echo "error: nerf-print-range: <end> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${END}" ]]; then
  echo "error: nerf-print-range: missing required argument <end>" >&2
  echo "  hint: provide a value for <end>" >&2
  usage
fi

_NERF_PATTERN='^[1-9][0-9]*$'
if [[ -n "${_END_SET}" ]] && ! [[ "${END}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-print-range: argument <end> does not match required pattern" >&2
  echo "  value:   \"${END}\"" >&2
  echo "  pattern: ^[1-9][0-9]*$" >&2
  echo "  hint: value must match ^[1-9][0-9]*$" >&2
  exit 1
fi

if [[ -n "${_FILE_SET}" ]] && [[ "${FILE}" == -* ]]; then
  echo "error: nerf-print-range: <file> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(sed -n "${START},${END}p; ${END}q" ${_FILE_SET:+"$FILE"})
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec sed -n "${START},${END}p; ${END}q" ${_FILE_SET:+"$FILE"}
