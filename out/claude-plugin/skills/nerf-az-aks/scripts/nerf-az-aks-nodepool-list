#!/usr/bin/env bash
# nerf-az-aks-nodepool-list -- List node pools on an AKS cluster
# Generated from az-aks manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-aks-nodepool-list --resource-group|-g <resource_group> [--subscription <subscription>] <cluster_name>

Options:
  --resource-group, -g <resource_group> (required)
      Resource group containing the cluster
  --subscription <subscription>
      Subscription name or ID (defaults to active)

Arguments:
  <cluster_name> (required)
      AKS cluster name

Maps to: az aks nodepool list --resource-group <resource_group> --cluster-name <cluster_name> <subscription> --output json

List node pools on an AKS cluster.
EOF
  exit 1
}

RESOURCE_GROUP=""
SUBSCRIPTION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --resource-group|-g) if [[ -n "${RESOURCE_GROUP}" ]]; then echo "error: --resource-group can only be specified once" >&2; exit 1; fi; RESOURCE_GROUP="$2"; shift 2 ;;
    --subscription) if [[ -n "${SUBSCRIPTION}" ]]; then echo "error: --subscription can only be specified once" >&2; exit 1; fi; SUBSCRIPTION="$2"; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

CLUSTER_NAME="${1:-}"
shift 2>/dev/null || true
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-aks-nodepool-list: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -z "${RESOURCE_GROUP}" ]]; then
  echo "error: nerf-az-aks-nodepool-list: missing required option --resource-group" >&2
  echo "  hint: provide --resource-group <value>" >&2
  usage
fi

if [[ -n "${CLUSTER_NAME}" ]] && [[ "${CLUSTER_NAME}" == -* ]]; then
  echo "error: nerf-az-aks-nodepool-list: <cluster_name> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${CLUSTER_NAME}" ]]; then
  echo "error: nerf-az-aks-nodepool-list: missing required argument <cluster_name>" >&2
  echo "  hint: provide a value for <cluster_name>" >&2
  usage
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az aks nodepool list --resource-group "${RESOURCE_GROUP}" --cluster-name "${CLUSTER_NAME}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az aks nodepool list --resource-group "${RESOURCE_GROUP}" --cluster-name "${CLUSTER_NAME}" ${SUBSCRIPTION:+"--subscription"} ${SUBSCRIPTION:+"$SUBSCRIPTION"} --output json
