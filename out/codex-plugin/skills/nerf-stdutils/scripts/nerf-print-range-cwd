#!/usr/bin/env bash
# nerf-print-range-cwd -- Print a line range from a workspace file. Like print-range, but <file> is required and must resolve under the current directory (workspace-scoped read). Use this when you specifically want to read a file in the repo; use print-range for machine-scope reads or for filtering a piped stream.
# Generated from stdutils manifest. Do not edit directly.
# nerf:threat:read=workspace
# nerf:threat:write=none

if [[ "${BASH_VERSINFO[0]:-0}" -lt 4 ]]; then
  echo "error: nerf-print-range-cwd requires bash 4+. Found bash ${BASH_VERSION:-unknown}" >&2
  echo "  hint: on macOS, install a newer bash via 'brew install bash'" >&2
  exit 1
fi

set -euo pipefail

NERFTOOLS_BRAND="nerf"

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-print-range-cwd <start> <end> <file>

Arguments:
  <start> (required)
      First line number (1-indexed, inclusive)
      Must match: ^[1-9][0-9]*$
  <end> (required)
      Last line number (1-indexed, inclusive)
      Must match: ^[1-9][0-9]*$
  <file> (required)
      File to read (must be under the current directory)

Maps to: sed -n <start>,<end>p; <end>q <file>

Print a line range from a workspace file. Like print-range, but <file> is required and must resolve under the current directory (workspace-scoped read). Use this when you specifically want to read a file in the repo; use print-range for machine-scope reads or for filtering a piped stream.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

_START_SET=""
if [[ $# -gt 0 ]]; then
  START="$1"
  _START_SET=true
  shift
else
  START=""
fi
_END_SET=""
if [[ $# -gt 0 ]]; then
  END="$1"
  _END_SET=true
  shift
else
  END=""
fi
_FILE_SET=""
if [[ $# -gt 0 ]]; then
  FILE="$1"
  _FILE_SET=true
  shift
else
  FILE=""
fi
if [[ $# -gt 0 ]]; then
  echo "error: nerf-print-range-cwd: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

for _bin in sed; do
  if ! command -v -- "$_bin" >/dev/null 2>&1; then
    echo "error: nerf-print-range-cwd: required command '$_bin' is not installed or not on PATH" >&2
    exit 127
  fi
done

_nerf_check_path() {
  local _label=$1 _input=$2 _tests=$3
  local _cwd _canonical
  case "$_input" in
    *$'\n'*|*$'\r'*|*$'\t'*)
      echo "error: nerf-print-range-cwd: ${_label}: contains illegal control character" >&2
      echo "  hint: paths must not contain newlines, carriage returns, or tabs" >&2
      return 1 ;;
  esac
  _cwd=$(realpath -- "$PWD") || {
    echo "error: nerf-print-range-cwd: failed to canonicalize cwd '$PWD'" >&2
    echo "  hint: invoke from a valid directory" >&2
    return 1
  }
  _canonical=$(realpath -m -- "$_input") || {
    echo "error: nerf-print-range-cwd: ${_label}: failed to canonicalize '${_input}'" >&2
    echo "  hint: pass a syntactically valid path" >&2
    return 1
  }
  if [[ ",$_tests," == *",under_cwd,"* ]]; then
    # Skip the prefix check when cwd is root: every absolute path qualifies, and the
    # naive prefix comparison would build "//" and reject otherwise-valid paths.
    if [[ "$_cwd" != "/" && "$_canonical" != "$_cwd" && "$_canonical" != "$_cwd"/* ]]; then
      echo "error: nerf-print-range-cwd: ${_label}: 'under_cwd' failed: '${_input}'" >&2
      echo "  resolves to '${_canonical}', not under '${_cwd}'" >&2
      echo "  hint: pass a path inside the current workspace" >&2
      echo "  hint: symlinks are followed -- if the link's target is outside the workspace it is rejected" >&2
      return 1
    fi
  fi
  if [[ ",$_tests," == *",exists,"* ]] && [[ ! -e "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'exists' failed: '${_input}' does not exist" >&2
    echo "  hint: create the path or pass an existing one" >&2
    return 1
  fi
  if [[ ",$_tests," == *",not_exists,"* ]] && [[ -e "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'not_exists' failed: '${_input}' already exists" >&2
    echo "  hint: choose a different path or remove the existing one first" >&2
    return 1
  fi
  if [[ ",$_tests," == *",file,"* ]] && [[ ! -f "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'file' failed: '${_input}' is not a regular file" >&2
    echo "  hint: pass a regular file path (not a directory, symlink-to-dir, device, or missing path)" >&2
    return 1
  fi
  if [[ ",$_tests," == *",dir,"* ]] && [[ ! -d "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'dir' failed: '${_input}' is not a directory" >&2
    echo "  hint: pass a directory path (not a regular file or missing path)" >&2
    return 1
  fi
  if [[ ",$_tests," == *",symlink,"* ]] && [[ ! -L "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'symlink' failed: '${_input}' is not a symlink" >&2
    echo "  hint: pass a symbolic link (the test does not follow the link)" >&2
    return 1
  fi
  if [[ ",$_tests," == *",not_symlink,"* ]] && [[ -L "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'not_symlink' failed: '${_input}' is a symlink" >&2
    echo "  hint: pass a real path, not a symlink (the test does not follow the link)" >&2
    return 1
  fi
  if [[ ",$_tests," == *",readable,"* ]] && [[ ! -r "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'readable' failed: '${_input}' is not readable" >&2
    echo "  hint: check filesystem permissions for the current user" >&2
    return 1
  fi
  if [[ ",$_tests," == *",writable,"* ]] && [[ ! -w "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'writable' failed: '${_input}' is not writable" >&2
    echo "  hint: check filesystem permissions for the current user" >&2
    return 1
  fi
  if [[ ",$_tests," == *",executable,"* ]] && [[ ! -x "$_input" ]]; then
    echo "error: nerf-print-range-cwd: ${_label}: 'executable' failed: '${_input}' is not executable" >&2
    echo "  hint: check filesystem permissions for the current user" >&2
    return 1
  fi
}

if [[ -n "${_START_SET}" ]] && [[ "${START}" == -* ]]; then
  echo "error: nerf-print-range-cwd: <start> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${START}" ]]; then
  echo "error: nerf-print-range-cwd: missing required argument <start>" >&2
  echo "  hint: provide a value for <start>" >&2
  usage
fi

_NERF_PATTERN='^[1-9][0-9]*$'
if [[ -n "${_START_SET}" ]] && ! [[ "${START}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-print-range-cwd: argument <start> does not match required pattern" >&2
  echo "  value:   \"${START}\"" >&2
  echo "  pattern: ^[1-9][0-9]*$" >&2
  echo "  hint: value must match ^[1-9][0-9]*$" >&2
  exit 1
fi

if [[ -n "${_END_SET}" ]] && [[ "${END}" == -* ]]; then
  echo "error: nerf-print-range-cwd: <end> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${END}" ]]; then
  echo "error: nerf-print-range-cwd: missing required argument <end>" >&2
  echo "  hint: provide a value for <end>" >&2
  usage
fi

_NERF_PATTERN='^[1-9][0-9]*$'
if [[ -n "${_END_SET}" ]] && ! [[ "${END}" =~ $_NERF_PATTERN ]]; then
  echo "error: nerf-print-range-cwd: argument <end> does not match required pattern" >&2
  echo "  value:   \"${END}\"" >&2
  echo "  pattern: ^[1-9][0-9]*$" >&2
  echo "  hint: value must match ^[1-9][0-9]*$" >&2
  exit 1
fi

if [[ -n "${_FILE_SET}" ]] && [[ "${FILE}" == -* ]]; then
  echo "error: nerf-print-range-cwd: <file> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${FILE}" ]]; then
  echo "error: nerf-print-range-cwd: missing required argument <file>" >&2
  echo "  hint: provide a value for <file>" >&2
  usage
fi

if [[ -n "${_FILE_SET}" ]]; then
  _nerf_check_path 'argument <file>' "${FILE}" 'under_cwd' || exit 1
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(sed -n "${START},${END}p; ${END}q" "${FILE}")
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec sed -n "${START},${END}p; ${END}q" "${FILE}"
