#!/usr/bin/env bash
# nerf-az-storage-account-network-rule-list -- List explicit network rules on a storage account.
# Generated from az-storage manifest. Do not edit directly.
# nerf:threat:read=remote
# nerf:threat:write=none

set -euo pipefail

_NERF_DRY_RUN=""

usage() {
  cat >&2 <<'EOF'
Usage: nerf-az-storage-account-network-rule-list --resource-group|-g <resource_group> [--subscription <subscription>] <account_name>

Options:
  --resource-group, -g <resource_group> (required)
      Resource group containing the storage account
  --subscription <subscription>
      Subscription name or ID (defaults to active)

Arguments:
  <account_name> (required)
      Storage account name

Maps to: az storage account network-rule list --resource-group <resource_group> --account-name <account_name> <subscription> --output json

List explicit network rules on a storage account.
EOF
  exit 1
}

RESOURCE_GROUP=""
_RESOURCE_GROUP_SET=""
SUBSCRIPTION=""
_SUBSCRIPTION_SET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --resource-group|-g) if [[ -n "${_RESOURCE_GROUP_SET}" ]]; then echo "error: --resource-group can only be specified once" >&2; exit 1; fi; RESOURCE_GROUP="$2"; _RESOURCE_GROUP_SET=true; shift 2 ;;
    --subscription) if [[ -n "${_SUBSCRIPTION_SET}" ]]; then echo "error: --subscription can only be specified once" >&2; exit 1; fi; SUBSCRIPTION="$2"; _SUBSCRIPTION_SET=true; shift 2 ;;
    --nerf-dry-run) _NERF_DRY_RUN="true"; shift 1 ;;
    -h|--help) usage ;;
    --) shift; break ;;
    *) break ;;
  esac
done

_ACCOUNT_NAME_SET=""
if [[ $# -gt 0 ]]; then
  ACCOUNT_NAME="$1"
  _ACCOUNT_NAME_SET=true
  shift
else
  ACCOUNT_NAME=""
fi
if [[ $# -gt 0 ]]; then
  echo "error: nerf-az-storage-account-network-rule-list: unexpected extra arguments: $*" >&2
  echo "  hint: switches and options must come before positional arguments" >&2
  exit 1
fi

if [[ -z "${RESOURCE_GROUP}" ]]; then
  echo "error: nerf-az-storage-account-network-rule-list: missing required option --resource-group" >&2
  echo "  hint: provide --resource-group <value>" >&2
  usage
fi

if [[ -n "${_ACCOUNT_NAME_SET}" ]] && [[ "${ACCOUNT_NAME}" == -* ]]; then
  echo "error: nerf-az-storage-account-network-rule-list: <account_name> cannot start with '-'" >&2
  echo "  hint: use -- before positional arguments if needed" >&2
  exit 1
fi

if [[ -z "${ACCOUNT_NAME}" ]]; then
  echo "error: nerf-az-storage-account-network-rule-list: missing required argument <account_name>" >&2
  echo "  hint: provide a value for <account_name>" >&2
  usage
fi

if [[ "$_NERF_DRY_RUN" == "true" ]]; then
  _NERF_DRY_CMD=(az storage account network-rule list --resource-group "${RESOURCE_GROUP}" --account-name "${ACCOUNT_NAME}" ${_SUBSCRIPTION_SET:+"--subscription"} ${_SUBSCRIPTION_SET:+"$SUBSCRIPTION"} --output json)
  printf 'dry-run:'
  for _a in "${_NERF_DRY_CMD[@]}"; do printf " %q" "$_a"; done
  echo
  exit 0
fi

exec az storage account network-rule list --resource-group "${RESOURCE_GROUP}" --account-name "${ACCOUNT_NAME}" ${_SUBSCRIPTION_SET:+"--subscription"} ${_SUBSCRIPTION_SET:+"$SUBSCRIPTION"} --output json
